<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ATWA — UAE Business Compliance & Risk Assessment</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
   <link rel="stylesheet" href="css/styles.css">
</head>
<body>
    <!-- Brand Bar -->
    <div class="brandbar hex-bg">
        <div class="atwa-mark">
            <svg viewBox="0 0 170 60" width="72" height="26">
                <polygon points="4,54 22,6 40,54" fill="none" stroke="#FFFFFF" stroke-width="3" stroke-linejoin="round"/>
                <polygon points="46,54 62,14 78,54" fill="#FFFFFF"/>
                <path d="M84,54 L96,20 L104,38 L116,14 L128,54 Z" fill="none" stroke="#FFFFFF" stroke-width="3" stroke-linejoin="round"/>
                <polygon points="134,54 150,6 166,54" fill="#FFFFFF"/>
            </svg>
            <div class="atwa-wordblock">
                <span class="name">ATWA</span>
                <span class="sub">Accounting &amp; Taxation</span>
            </div>
        </div>
        <div class="tagline">Compliance &amp; Risk Assessment</div>
    </div>

    <!-- LANDING SCREEN -->
    <section id="screen-landing" class="screen active">
        <div class="hex-bg">
            <div class="hero">
                <div class="hero-eyebrow">5-minute self assessment</div>
                <h1>Is your UAE business actually <span>compliant</span> — or just hoping it is?</h1>
                <p class="lede">Answer 22 questions across accounting, VAT, corporate tax, payroll, audit and licensing. Get a scored risk profile, a prioritised action plan, and a branded PDF report from ATWA Accounting &amp; Taxation LLC.</p>
                <div class="hero-cta">
                    <button class="btn" id="startAssessmentBtn">Start assessment &nbsp;→</button>
                </div>
                <div class="hero-stats">
                    <div class="hero-stat"><span class="num">22</span><span class="label">Questions</span></div>
                    <div class="hero-stat"><span class="num">6</span><span class="label">Risk categories</span></div>
                    <div class="hero-stat"><span class="num">~4 min</span><span class="label">Typical time</span></div>
                    <div class="hero-stat"><span class="num">15+ yrs</span><span class="label">ATWA experience</span></div>
                </div>
            </div>
        </div>
        <div class="trust-strip">
            <div class="strip-label">Why business owners trust ATWA</div>
            <div class="chip-row">
                <span class="chip">FTA-approved tax agency</span>
                <span class="chip">15+ years of experience</span>
                <span class="chip">ACCA · CPA · CMA certified team</span>
                <span class="chip">Business Bay &amp; Garhoud, Dubai</span>
                <span class="chip">Accounting · Audit · Tax · Business Setup · PRO</span>
            </div>
        </div>
    </section>

    <!-- WIZARD SCREEN -->
    <section id="screen-wizard" class="screen">
        <div class="wizard-wrap">
            <div class="progress-row">
                <div class="progress-track">
                    <div class="progress-fill" id="progressFill"></div>
                </div>
                <div class="progress-count" id="progressCount">Step 1 of 8</div>
            </div>
            <div id="stepContent"></div>
            <div class="wizard-nav">
                <button class="btn btn-ghost light" id="backBtn">← Back</button>
                <button class="btn" id="nextBtn">Continue →</button>
            </div>
        </div>
    </section>

    <!-- RESULTS SCREEN -->
    <section id="screen-results" class="screen">
        <div class="results-wrap">
            <div class="results-head">
                <div class="gauge-wrap">
                    <svg viewBox="0 0 220 220" width="220" height="220">
                        <circle cx="110" cy="110" r="94" fill="none" stroke="#EDEAE2" stroke-width="14"/>
                        <circle id="gaugeArc" cx="110" cy="110" r="94" fill="none" stroke="#A6373A" stroke-width="14"
                                stroke-linecap="round" transform="rotate(-90 110 110)" stroke-dasharray="0 590"/>
                    </svg>
                    <div class="gauge-center">
                        <span class="gauge-score" id="gaugeScore">0</span>
                        <span class="gauge-tier" id="gaugeTier">—</span>
                    </div>
                </div>
                <div class="results-headtext">
                    <div class="step-eyebrow" id="companyNameLabel">Your Results</div>
                    <h2>Overall Business Health</h2>
                    <p id="resultsSummary">Here's how your business scores across the categories that matter most to the FTA and your license authority.</p>
                    <div class="value-strip">
                        <div class="value-metric"><span class="num" id="valueScoreNum">—</span><span class="label">Business Value Score</span></div>
                        <div class="value-metric"><span class="num" id="riskCountNum">—</span><span class="label">Risks flagged</span></div>
                        <div class="value-metric"><span class="num" id="strengthCountNum">—</span><span class="label">Strengths found</span></div>
                    </div>
                </div>
            </div>

            <div class="cat-breakdown">
                <div class="section-label">Category breakdown</div>
                <div id="categoryRows"></div>
            </div>

            <div class="two-col">
                <div class="list-card">
                    <h3>Strengths</h3>
                    <ul id="strengthsList"></ul>
                </div>
                <div class="list-card">
                    <h3>Risks</h3>
                    <ul id="risksList"></ul>
                </div>
            </div>

            <div class="actions-block">
                <div class="section-label">Recommended actions</div>
                <div id="actionsList"></div>
            </div>

            <!-- Lead Capture -->
            <div class="capture-card hex-bg">
                <h3>Get your full ATWA report</h3>
                <p>Enter your details to unlock a branded PDF of this assessment — every score, risk, and recommendation — plus the option to book a complimentary review with one of our advisors.</p>
                <div class="capture-grid">
                    <input type="text" id="leadName" placeholder="Full name" aria-label="Full name">
                    <input type="text" id="leadCompany" placeholder="Company name" aria-label="Company name">
                    <input type="email" id="leadEmail" placeholder="Email address" aria-label="Email address">
                    <input type="tel" id="leadPhone" placeholder="Phone number" aria-label="Phone number">
                </div>
                <label class="capture-checkbox">
                    <input type="checkbox" id="leadConsult" style="margin-top:2px;">
                    <span>I'd like a complimentary review of this assessment with an ATWA advisor.</span>
                </label>
                <div style="display:flex; gap:14px; flex-wrap:wrap;">
                    <button class="btn" id="unlockBtn">Unlock report</button>
                </div>
                <div class="post-capture" id="postCapture">
                    <button class="btn" id="downloadPdfBtn">↓ Download PDF report</button>
                    <button class="btn btn-ghost" id="bookConsultBtn">Book consultation →</button>
                </div>
                <div class="contact-strip">
                    <div><strong>Call us</strong>+971 50 777 9293 · +971 50 777 9294</div>
                    <div><strong>Email</strong>info@atwa.ae</div>
                    <div><strong>Business Bay</strong>Tamani Art Offices, 12th Floor, No. 1254</div>
                    <div><strong>Garhoud</strong>Zalfa Building, 3rd Floor, No. 104</div>
                </div>
            </div>

            <div style="text-align:center;">
                <button class="restart-link" id="restartBtn">↺ Start a new assessment</button>
            </div>
        </div>

        <footer class="disclaimer">
            This assessment is provided by ATWA Accounting &amp; Taxation LLC for general informational purposes only and does not constitute legal, tax, or accounting advice. Scores are indicative, based solely on self-reported answers, and should not be relied upon for compliance decisions. Please consult a qualified advisor before acting on any recommendation shown here.
        </footer>
    </section>

    <!-- Scripts -->
<!-- Scripts -->
<script src="js/core/config.js"></script>
<script src="js/core/constants.js"></script>
<script src="js/core/state-manager.js"></script>
<script src="js/data/assessment-data.js"></script>
<script src="js/services/validation-service.js"></script>
<script src="js/services/scoring-engine.js"></script>
<script src="js/services/pdf-generator.js"></script>
<script src="js/ui/renderer.js"></script>
<script src="js/ui/wizard.js"></script>
<script src="js/ui/results.js"></script>
<script src="js/utils/helpers.js"></script>
<script src="js/app.js"></script>
</body>
</html>
